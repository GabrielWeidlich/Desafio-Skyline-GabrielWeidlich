{
  "name": "nodejs-typescript-drizzle-project",
  "version": "1.0.0",
  "description": "Full Stack Node.js project with TypeScript, PostgreSQL and Drizzle ORM",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate:pg",
    "db:migrate": "drizzle-kit push:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:migrate-and-start": "./scripts/migrate.sh && npm run dev",
    "test": "jest"
  },
  "keywords": ["nodejs", "typescript", "drizzle", "postgresql", "docker"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "drizzle-orm": "^0.29.4",
    "pg": "^8.11.3",
    "express": "^4.18.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/jest": "^29.5.8",
    "drizzle-kit": "^0.20.7",
    "jest": "^29.7.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
